# KHÔNG commit key thật — chỉ để placeholder ở đây
VITE_FREELLMAPI_KEY=freellmapi-your-unified-key-here
VITE_FREELLMAPI_URL=http://localhost:3001/v1

# App Settings
VITE_APP_NAME=Project Tracker
VITE_APP_VERSION=1.0.0
